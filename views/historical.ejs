<%- include("partials/header.ejs") %>

<main class="dashboard-content">
    <div class="page-header">
        <h1>Historical Index Archives</h1>
        <p>Audit closing international exchange rates dating back to 1999.</p>
    </div>

    <% if (error) { %>
        <div class="error-banner">
            <p><strong>System Alert:</strong> <%= error %></p>
        </div>
    <% } %>

    <section class="control-panel">
        <form action="/historical" method="GET" class="filter-form">
            <div class="form-group">
                <label for="date-select">Select Target Date:</label>
                <input type="date" name="date" id="date-select" class="custom-input" value="<%= date %>" max="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>
            
            <div class="form-group">
                <label for="base-select">Select Benchmark Currency:</label>
                <select name="base" id="base-select" class="custom-select">
                    <% for (const code in currencyList) { %>
                        <option value="<%= code %>" <%= code === base ? 'selected' : '' %>>
                            <%= code %> - <%= currencyList[code] %>
                        </option>
                    <% } %>
                </select>
            </div>
            <button type="submit" class="btn-primary">Query Archives</button>
        </form>
    </section>

    <% if (Object.keys(rates).length > 0) { %>
        <section class="data-card">
            <div class="card-meta">
                <h3>Closing Metrics For: <span class="text-highlight"><%= base %></span></h3>
                <p>Archived Date of Record: <strong><%= date %></strong></p>
            </div>

            <table class="analytics-table">
                <thead>
                    <tr>
                        <th>Asset Class (Currency)</th>
                        <th>Historical Index Value</th>
                    </tr>
                </thead>
                <tbody>
                    <% for (const currency in rates) { %>
                        <tr>
                            <td class="asset-code"><strong><%= currency %></strong></td>
                            <td class="asset-value"><%= rates[currency] %></td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </section>
    <% } else if (date === "") { %>
        <div class="info-banner">
            <p>Please specify a target date parameters above to initiate audit logs.</p>
        </div>
    <% } %>
</main>

<%- include("partials/footer.ejs") %>